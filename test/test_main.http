GET {{host}}/api/taste-map/points
Authorization: Bearer {{token1}}

### 按餐厅名筛选
GET {{host}}/api/taste-map/points?restaurant=海底捞
Authorization: Bearer {{token1}}

########################################
# 10. 成就系统
########################################

### 获取所有成就定义
GET {{host}}/api/achievements
Authorization: Bearer {{token1}}

### 获取当前用户的成就进度（Alice）
GET {{host}}/api/users/me/achievements
Authorization: Bearer {{token1}}

### 获取当前用户的成就进度（Bob）
GET {{host}}/api/users/me/achievements
Authorization: Bearer {{token2}}

########################################
# 11. 爱情银行
########################################

### 查看当前用户爱情币余额（Alice）
GET {{host}}/api/users/me/love-coins
Authorization: Bearer {{token1}}

### 查看当前用户爱情币余额（Bob）
GET {{host}}/api/users/me/love-coins
Authorization: Bearer {{token2}}

### 查看当前用户积分流水
GET {{host}}/api/users/me/love-coin-transactions?page=1&size=20
Authorization: Bearer {{token1}}

### 查看可兑换特权列表
GET {{host}}/api/redeem-items
Authorization: Bearer {{token1}}

### 兑换「免洗碗特权」（需200爱情币）
POST {{host}}/api/redeem
Authorization: Bearer {{token1}}
Content-Type: {{contentType}}

{
  "itemId": 1
}

### 兑换「一星不生气券」（需500爱情币）
POST {{host}}/api/redeem
Authorization: Bearer {{token1}}
Content-Type: {{contentType}}

{
  "itemId": 3
}

### 再兑换2张一星不生气券（为合成做准备）
POST {{host}}/api/redeem
Authorization: Bearer {{token1}}
Content-Type: {{contentType}}

{
  "itemId": 3
}

###
POST {{host}}/api/redeem
Authorization: Bearer {{token1}}
Content-Type: {{contentType}}

{
  "itemId": 3
}

### 查看当前用户背包（应有3张一星不生气券+1个免洗碗特权）
GET {{host}}/api/users/me/inventory
Authorization: Bearer {{token1}}

### 合成二星不生气券（传入3张一星的 redemption_id）
# seed 数据：redemption 1,2,3 为一星不生气券，4 为免洗碗。合成需 [1,2,3]
# 若 DB 非 seed 初始，请先运行 inventory 获取实际 redemption_id
POST {{host}}/api/redeem/synthesize
Authorization: Bearer {{token1}}
Content-Type: {{contentType}}

{
  "itemIds": [1, 2, 3]
}

### 合成后再查看背包（一星消失，多了一张二星）
GET {{host}}/api/users/me/inventory
Authorization: Bearer {{token1}}

### 查看合成后的爱情币余额
GET {{host}}/api/users/me/love-coins
Authorization: Bearer {{token1}}

########################################
# 12. 情绪温度计
########################################

### 获取全部情绪统计
GET {{host}}/api/moods/statistics
Authorization: Bearer {{token1}}

### 按时间范围查询情绪统计
GET {{host}}/api/moods/statistics?startDate=2026-03-01&endDate=2026-03-31
Authorization: Bearer {{token1}}

########################################
# 13. 选择困难症拯救器
########################################

### 随机推荐3道菜（自动结合当前用户偏好）
GET {{host}}/api/recommendations?count=3
Authorization: Bearer {{token1}}

### 指定餐厅推荐
GET {{host}}/api/recommendations?restaurant=海底捞&count=2
Authorization: Bearer {{token1}}

### 根据心情推荐（甜 → 偏甜品类）
GET {{host}}/api/recommendations?mood=甜&count=3
Authorization: Bearer {{token1}}

########################################
# 14. 惊喜模式
########################################

### 查看惊喜模式状态（临近纪念日时自动激活）
GET {{host}}/api/surprise-mode/status
Authorization: Bearer {{token1}}

########################################
